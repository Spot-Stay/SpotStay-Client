<Window x:Class="코빚노_프로젝트.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="KoreaTravel"
        Width="1300"
        Height="820"
        MinWidth="1000"
        MinHeight="650"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        WindowStyle="None"
        ResizeMode="CanResize"
        Background="#F7F8FA"
        FontFamily="Malgun Gothic">

    <Window.Resources>

        <!-- 상단 검정 pill 버튼 -->
        <Style x:Key="TopDarkPillBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="#2F2F31"/>
            <Setter Property="CornerRadius" Value="18"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- 리스트 오른쪽 작은 아이콘 버튼 -->
        <Style x:Key="MiniIconButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,4,0,0"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Foreground" Value="#CFCFCF"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <ContentPresenter HorizontalAlignment="Center"
                                  VerticalAlignment="Center"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>

            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="#333333"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- 오른쪽 하단 둥근 액션 버튼 -->
        <Style x:Key="RightSideActionButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="34"/>
            <Setter Property="Width" Value="138"/>
            <Setter Property="Background" Value="#F7F7F7"/>
            <Setter Property="BorderBrush" Value="#D9D9D9"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="#444444"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,7,0,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="17">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FFFBEA"/>
                                <Setter Property="BorderBrush" Value="#FFCC00"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="YellowButton" TargetType="Button">
            <Setter Property="Background" Value="#FFCC00"/>
            <Setter Property="Foreground" Value="#333333"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="16"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GrayButton" TargetType="Button">
            <Setter Property="Background" Value="#F7F8FA"/>
            <Setter Property="Foreground" Value="#555555"/>
            <Setter Property="BorderBrush" Value="#E8E8E8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="14"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LoginButton" TargetType="Button">
            <Setter Property="Background" Value="#333333"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,7"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="18"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#111111"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#000000"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SearchIconButton" TargetType="Button">
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Background" Value="#FFCC00"/>
            <Setter Property="Foreground" Value="#333333"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="16">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="WindowTopButton" TargetType="Button">
            <Setter Property="Width" Value="42"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#444444"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#EEEEEE"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CloseWindowTopButton" TargetType="Button" BasedOn="{StaticResource WindowTopButton}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E81123"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- 왼쪽 관광지 카드 하트 버튼 -->
        <Style x:Key="TourHeartButton" TargetType="Button">
            <Setter Property="Content" Value="♡"/>
            <Setter Property="ToolTip" Value="즐겨찾기"/>
            <Setter Property="Foreground" Value="#DDDDDD"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>

            <Style.Triggers>
                <DataTrigger Binding="{Binding IsFavorite}" Value="True">
                    <Setter Property="Content" Value="♥"/>
                    <Setter Property="Foreground" Value="#FF4B5C"/>
                </DataTrigger>

                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="#FF4B5C"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="RegionComboBox" TargetType="ComboBox">
            <Setter Property="Width" Value="190"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#333333"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton"
                                          Focusable="False"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          ClickMode="Press">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="ComboBorder"
                                                Background="White"
                                                BorderBrush="#E0E0E0"
                                                BorderThickness="1"
                                                CornerRadius="17">
                                            <Grid>
                                                <Border Width="24"
                                                        Height="24"
                                                        CornerRadius="12"
                                                        Background="#FFCC00"
                                                        HorizontalAlignment="Right"
                                                        VerticalAlignment="Center"
                                                        Margin="0,0,6,0">
                                                    <TextBlock Text="⌄"
                                                               FontSize="13"
                                                               FontWeight="Bold"
                                                               Foreground="#333333"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"
                                                               Margin="0,-2,0,0"/>
                                                </Border>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="ComboBorder"
                                                        Property="BorderBrush"
                                                        Value="#FFCC00"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>

                            <ContentPresenter IsHitTestVisible="False"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                              Margin="14,0,40,0"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Left"/>

                            <Popup Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Slide">
                                <Border Background="White"
                                        BorderBrush="#E0E0E0"
                                        BorderThickness="1"
                                        CornerRadius="12"
                                        Margin="0,4,0,0"
                                        Padding="4"
                                        MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}">
                                    <ScrollViewer MaxHeight="220">
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RegionComboBoxItem" TargetType="ComboBoxItem">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="12,7"/>
            <Setter Property="Foreground" Value="#333333"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="ItemBorder"
                                Background="Transparent"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ItemBorder"
                                        Property="Background"
                                        Value="#FFF8CC"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder"
                                        Property="Background"
                                        Value="#FFCC00"/>
                                <Setter Property="FontWeight"
                                        Value="Bold"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <DataTemplate x:Key="TourSpotTemplate">
            <Border Padding="8"
                    BorderBrush="#F2F2F2"
                    BorderThickness="0,0,0,1"
                    Background="White"
                    MouseLeftButtonDown="TourSpotCard_Click"
                    Cursor="Hand">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="26"/>
                        <ColumnDefinition Width="50"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="34"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Width="22"
                            Height="22"
                            CornerRadius="11"
                            Background="#F0F0F0"
                            VerticalAlignment="Center">
                        <TextBlock Text="{Binding No}"
                                   FontSize="11"
                                   FontWeight="Bold"
                                   Foreground="#777"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>

                    <Border Grid.Column="1"
                            Width="42"
                            Height="42"
                            CornerRadius="10"
                            Background="#F7F8FA"
                            VerticalAlignment="Center">
                        <TextBlock Text="{Binding Icon}"
                                   FontSize="22"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>

                    <StackPanel Grid.Column="2"
            Margin="8,0,0,0"
            VerticalAlignment="Center">

                        <TextBlock Text="{Binding Name}"
               FontSize="13"
               FontWeight="Bold"
               Foreground="#222"
               TextTrimming="CharacterEllipsis"/>

                        <TextBlock Text="{Binding Address}"
               FontSize="11"
               Foreground="#999"
               Margin="0,2,0,0"
               TextTrimming="CharacterEllipsis"/>

                        <!-- 현재 위치 기준 거리 표시 -->
                        <TextBlock Text="{Binding DistanceText}"
               FontSize="10"
               FontWeight="Bold"
               Foreground="#1A73E8"
               Margin="0,2,0,0"
               TextTrimming="CharacterEllipsis"/>

                        <StackPanel Orientation="Horizontal"
                Margin="0,5,0,0">

                            <Border Background="#EAFAF1"
                CornerRadius="8"
                Padding="7,1">
                                <TextBlock Text="{Binding Category}"
                       FontSize="10"
                       Foreground="#1A7A4A"/>
                            </Border>

                            <TextBlock Text="{Binding SubCategory}"
                   FontSize="10"
                   Foreground="#777"
                   Margin="6,1,0,0"/>

                            <TextBlock Text="{Binding Rating}"
                   FontSize="10"
                   FontWeight="Bold"
                   Foreground="#FFCC00"
                   Margin="8,1,0,0"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- 오른쪽 하트 + 공유 -->
                    <StackPanel Grid.Column="3"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Top"
                                Margin="0,4,0,0">
                        <Button Style="{StaticResource TourHeartButton}"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Click="BtnTourCardFavorite_Click"/>

                        <Button Style="{StaticResource MiniIconButtonStyle}"
                                Click="BtnTourCardShare_Click"
                                ToolTip="공유하기">
                            <TextBlock FontFamily="Segoe MDL2 Assets"
           Text="&#xE72D;"
           FontSize="14"
           Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
           HorizontalAlignment="Center"
           VerticalAlignment="Center"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="StayTemplate">
            <Border Background="#F7F8FA"
                    CornerRadius="10"
                    BorderBrush="#F0F0F0"
                    BorderThickness="1"
                    Padding="10"
                    Margin="0,0,8,0"
                    Width="145">
                <StackPanel>
                    <TextBlock Text="{Binding Name}"
                               FontSize="11"
                               FontWeight="Bold"
                               Foreground="#333"
                               TextTrimming="CharacterEllipsis"/>
                    <TextBlock Text="{Binding Distance}"
                               FontSize="10"
                               Foreground="#999"
                               Margin="0,3,0,0"/>
                    <TextBlock Text="{Binding Price}"
                               FontSize="11"
                               FontWeight="Bold"
                               Foreground="#1A73E8"
                               Margin="0,3,0,0"/>
                    <Button Content="예약하기 →"
                            FontSize="10"
                            FontWeight="Bold"
                            Foreground="#D9A800"
                            Background="Transparent"
                            BorderThickness="0"
                            Padding="0"
                            HorizontalAlignment="Left"
                            Margin="0,3,0,0"
                            Cursor="Hand"
                            Click="BtnBookStay_Click"/>
                </StackPanel>
            </Border>
        </DataTemplate>

    </Window.Resources>

    <Border Margin="8"
            Background="#F7F8FA"
            BorderBrush="#E0E0E0"
            BorderThickness="1"
            CornerRadius="12"
            ClipToBounds="True">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="34"/>
                <RowDefinition Height="96"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- 커스텀 윈도우 상단바 -->
            <Grid Grid.Row="0"
                  Background="White"
                  MouseLeftButtonDown="CustomTitleBar_MouseLeftButtonDown">

                <TextBlock Text="Spot Stay"
                           VerticalAlignment="Center"
                           Margin="14,0,0,0"
                           FontSize="12"
                           FontWeight="Bold"
                           Foreground="#333333"/>

                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right">

                    <Button x:Name="BtnWindowMinimize"
                            Content="─"
                            Style="{StaticResource WindowTopButton}"
                            Click="BtnWindowMinimize_Click"/>

                    <Button x:Name="BtnWindowMaximize"
                            Content="□"
                            Style="{StaticResource WindowTopButton}"
                            Click="BtnWindowMaximize_Click"/>

                    <Button x:Name="BtnWindowClose"
                            Content="✕"
                            Style="{StaticResource CloseWindowTopButton}"
                            Click="BtnWindowClose_Click"/>
                </StackPanel>
            </Grid>

            <!-- 상단 헤더 -->
            <Border Grid.Row="1"
                    Background="White"
                    BorderBrush="#F2F2F2"
                    BorderThickness="0,1,0,1"
                    Padding="16,12">
                <Grid Margin="0,0,0,-11">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="38"/>
                        <RowDefinition Height="34"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="130"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="360"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   VerticalAlignment="Center"
                                   FontSize="18"
                                   FontWeight="ExtraBold">
                            <Run Text="Spot"/>
                            <Run Text="Stay" Foreground="#FFCC00"/>
                        </TextBlock>

                        <Border Grid.Column="1"
                                Background="#F7F8FA"
                                BorderBrush="#E0E0E0"
                                BorderThickness="1.5"
                                CornerRadius="20"
                                Padding="15,0"
                                Margin="0,0,12,0">
                            <Grid>
                                <TextBox x:Name="TxtSearch"
         Text=""
         BorderThickness="0"
         Background="Transparent"
         VerticalContentAlignment="Center"
         FontSize="13"
         Foreground="#333"
         Margin="0,0,42,0"
         KeyDown="TxtSearch_KeyDown"/>

                                <Button Content="🔍"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Center"
                                        Margin="0,0,2,0"
                                        Style="{StaticResource SearchIconButton}"
                                        Click="BtnSearch_Click"/>
                            </Grid>
                        </Border>

                        <StackPanel Grid.Column="2"
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center">

                            <!-- 친구창 버튼 -->
                            <Border x:Name="FriendBox"
                                    Style="{StaticResource TopDarkPillBorderStyle}"
                                    Margin="0,0,10,0"
                                    MouseLeftButtonDown="FriendBox_MouseLeftButtonDown">
                                <StackPanel Orientation="Horizontal"
                                            VerticalAlignment="Center"
                                            HorizontalAlignment="Center">
                                    <TextBlock Text="👥"
                                               Foreground="White"
                                               FontSize="12"
                                               VerticalAlignment="Center"
                                               Margin="0,0,6,0"/>
                                    <TextBlock Text="채팅창"
                                               Foreground="White"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>

                            <Button x:Name="BtnLogin"
                                    Content="👤 로그인"
                                    Width="92"
                                    Height="36"
                                    Margin="0,0,0,0"
                                    Style="{StaticResource LoginButton}"
                                    Click="BtnLogin_Click"/>

                            <Border x:Name="UserBox"
                                    Width="110"
                                    Height="36"
                                    Margin="10,0,6,0"
                                    Background="#333333"
                                    CornerRadius="18"
                                    Visibility="Collapsed"
                                    Cursor="Hand"
                                    PreviewMouseLeftButtonDown="UserBox_PreviewMouseLeftButtonDown">
                                <TextBlock x:Name="TxtLoginUser"
                                           Text=""
                                           Foreground="White"
                                           FontSize="12"
                                           FontWeight="Bold"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis"/>
                            </Border>

                        </StackPanel>
                    </Grid>

                    <Grid Grid.Row="1"
                          Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="190"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel x:Name="CategoryPanel"
                                    Grid.Column="0"
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Left">
                            <Button Content="전체"
                                    Style="{StaticResource YellowButton}"
                                    Margin="0,0,6,0"
                                    Click="Keyword_Click"/>

                            <Button Content="국립공원"
                                    Style="{StaticResource GrayButton}"
                                    Margin="0,0,6,0"
                                    Click="Keyword_Click"/>

                            <Button Content="문화유적"
                                    Style="{StaticResource GrayButton}"
                                    Margin="0,0,6,0"
                                    Click="Keyword_Click"/>

                            <Button Content="해변"
                                    Style="{StaticResource GrayButton}"
                                    Margin="0,0,6,0"
                                    Click="Keyword_Click"/>

                            <Button Content="맛집"
                                    Style="{StaticResource GrayButton}"
                                    Margin="0,0,6,0"
                                    Click="Keyword_Click"/>

                        </StackPanel>

                        <ComboBox x:Name="CmbRegion"
                                  Grid.Column="1"
                                  HorizontalAlignment="Center"
                                  SelectedIndex="0"
                                  Style="{StaticResource RegionComboBox}"
                                  ItemContainerStyle="{StaticResource RegionComboBoxItem}"
                                  SelectionChanged="CmbRegion_SelectionChanged"
                                  Margin="0,-5,0,-3"
                                  Width="190">
                            <ComboBoxItem Content="📍 서울특별시" Tag="서울특별시"/>
                            <ComboBoxItem Content="📍 제주특별자치도" Tag="제주특별자치도"/>
                            <ComboBoxItem Content="📍 대전광역시" Tag="대전광역시"/>
                            <ComboBoxItem Content="📍 강원도" Tag="강원도"/>
                            <ComboBoxItem Content="📍 경상남도" Tag="경상남도"/>
                            <ComboBoxItem Content="📍 전라남도" Tag="전라남도"/>
                        </ComboBox>
                    </Grid>
                </Grid>
            </Border>

            <!-- 본문 -->
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="0.32*" MinWidth="320" MaxWidth="430"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- 왼쪽 검색 결과 -->
                <Border Grid.Column="0"
                        Background="White"
                        BorderBrush="#F2F2F2"
                        BorderThickness="0,0,1,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="110"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0"
                                    Margin="14,12,14,8">
                            <TextBlock FontSize="13"
                                       FontWeight="Bold">
                                <Run Text="검색 결과 "/>
                                <Run x:Name="TxtResultCount"
                                     Text="7"
                                     Foreground="#FFCC00"/>
                                <Run Text="개"/>
                            </TextBlock>

                            <TextBlock x:Name="TxtResultSub"
                                       Text="서울특별시 · 전체 카테고리"
                                       FontSize="11"
                                       Foreground="#999"
                                       Margin="0,8,0,0"/>

                            <UniformGrid x:Name="SortPanel"
                                         Columns="3"
                                         Margin="0,12,0,0"
                                         Height="34">
                                <Button Content="거리순"
        Style="{StaticResource GrayButton}"
        FontSize="11"
        Padding="0"
        Margin="0,0,5,0"
        Focusable="False"
        Click="BtnSortDistance_Click"/>

                                <Button Content="별점순"
                                        Style="{StaticResource GrayButton}"
                                        FontSize="11"
                                        Padding="0"
                                        Margin="0,0,5,0"
                                        Focusable="False"
                                        Click="BtnSortRating_Click"/>

                                <Button Content="리뷰순"
                                        Style="{StaticResource GrayButton}"
                                        FontSize="11"
                                        Padding="0"
                                        Focusable="False"
                                        Click="BtnSortReview_Click"/>
                            </UniformGrid>
                        </StackPanel>

                        <ListBox x:Name="TourSpotList"
                                 Grid.Row="1"
                                 BorderThickness="0"
                                 HorizontalContentAlignment="Stretch"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 ItemTemplate="{StaticResource TourSpotTemplate}"
                                 SelectionChanged="TourSpotList_SelectionChanged"/>
                    </Grid>
                </Border>

                <!-- 오른쪽 지도 + 상세 -->
                <Grid Grid.Column="1"
                      Background="#E8E0D0"
                      ClipToBounds="True">

                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="190"/>
                    </Grid.RowDefinitions>

                    <!-- 지도 영역 -->
                    <Grid Grid.Row="0"
                          Background="White">

                        <wv2:WebView2 x:Name="MapWebView"
                                      HorizontalAlignment="Stretch"
                                      VerticalAlignment="Stretch"/>

                        <!-- 선택 관광지 이미지 카드 -->
                        <Border x:Name="TourImageOverlay"
                                Width="290"
                                Height="176"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Bottom"
                                Margin="28,0,0,24"
                                Background="White"
                                CornerRadius="16"
                                BorderBrush="#EEEEEE"
                                BorderThickness="1"
                                Visibility="Collapsed"
                                Panel.ZIndex="20">

                            <Border.Effect>
                                <DropShadowEffect BlurRadius="20"
                                                  ShadowDepth="2"
                                                  Opacity="0.20"/>
                            </Border.Effect>

                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="118"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <Border Grid.Row="0"
                                        CornerRadius="16,16,0,0"
                                        ClipToBounds="True"
                                        Background="#F4F4F4">
                                    <Grid>
                                        <Image x:Name="ImgTourPreview"
                                               Stretch="UniformToFill"/>

                                        <TextBlock Text="🏞️"
                                                   FontSize="42"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   Opacity="0.45"/>

                                        <Border HorizontalAlignment="Left"
                                                VerticalAlignment="Top"
                                                Margin="10"
                                                Background="#CCFFFFFF"
                                                CornerRadius="10"
                                                Padding="8,3">
                                            <TextBlock x:Name="TxtTourImageCategory"
                                                       Text="관광지"
                                                       FontSize="11"
                                                       FontWeight="Bold"
                                                       Foreground="#333333"/>
                                        </Border>
                                    </Grid>
                                </Border>

                                <Grid Grid.Row="1"
                                      Margin="12,8,12,8">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock x:Name="TxtTourImageTitle"
                                               Text="관광지명"
                                               FontSize="14"
                                               FontWeight="ExtraBold"
                                               Foreground="#222222"
                                               TextTrimming="CharacterEllipsis"/>

                                    <TextBlock x:Name="TxtTourImageAddress"
                                               Grid.Row="1"
                                               Text="주소"
                                               FontSize="11"
                                               Foreground="#999999"
                                               Margin="0,4,0,0"
                                               TextTrimming="CharacterEllipsis"/>
                                </Grid>
                            </Grid>
                        </Border>
                    </Grid>

                    <!-- 아래 상세 카드 영역 -->
                    <Border Grid.Row="1"
                            Margin="10,5,10,0"
                            Background="White"
                            CornerRadius="16"
                            Padding="16"
                            BorderBrush="#E8E8E8"
                            BorderThickness="1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="150"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0"
                                    Width="70"
                                    Height="70"
                                    Background="#F7F8FA"
                                    CornerRadius="12">
                                <TextBlock x:Name="TxtDetailIcon"
                                           Text="🏔️"
                                           FontSize="34"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>

                            <StackPanel Grid.Column="1">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock x:Name="TxtDetailName"
                                               Text="경복궁"
                                               FontSize="15"
                                               FontWeight="ExtraBold"
                                               Foreground="#222"/>

                                    <Border Background="#FFFBEA"
                                            CornerRadius="6"
                                            Padding="7,1"
                                            Margin="8,0,0,0">
                                        <TextBlock x:Name="TxtDetailCategory"
                                                   Text="🌿 국립공원"
                                                   FontSize="11"
                                                   FontWeight="Bold"
                                                   Foreground="#D9A800"/>
                                    </Border>
                                </StackPanel>

                                <TextBlock x:Name="TxtDetailAddress"
                                           Text="📍 서울특별시 종로구 사직로 161"
                                           FontSize="11"
                                           Foreground="#999"
                                           Margin="0,5,0,0"/>

                                <TextBlock x:Name="TxtDetailReviewSummary"
                                           Text="☆☆☆☆☆  0.0 · 리뷰 0개"
                                           FontSize="12"
                                           Foreground="#FFCC00"
                                           Margin="0,4,0,0"/>

                                <ItemsControl x:Name="StayList"
                                              Margin="0,10,0,0"
                                              ItemTemplate="{StaticResource StayTemplate}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Horizontal"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                </ItemsControl>
                            </StackPanel>

                            <StackPanel Grid.Column="2"
                                        HorizontalAlignment="Right">
                                <Button Content="주변 숙소 전체 보기"
                                        Style="{StaticResource YellowButton}"
                                        Margin="0,0,0,0"
                                        Click="BtnNearbyStay_Click"
                                        Width="138"/>

                                <Button x:Name="BtnDetailFavorite"
                                        Style="{StaticResource RightSideActionButtonStyle}"
                                                ToolTip="즐겨찾기"
                                        Click="BtnDetailFavorite_Click">
                                    <StackPanel Orientation="Horizontal"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center">
                                        <TextBlock Text="♡"
                                                   FontSize="14"
                                                   Margin="0,0,6,0"
                                                   Foreground="#666666"/>
                                        <TextBlock Text="즐겨찾기"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>

                                <Button Style="{StaticResource RightSideActionButtonStyle}"
                                        Click="BtnWriteReview_Click">
                                    <StackPanel Orientation="Horizontal"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center">
                                        <TextBlock Text="★"
                                                   FontSize="12"
                                                   Margin="0,0,6,0"
                                                   Foreground="#666666"/>
                                        <TextBlock Text="리뷰 쓰기"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>

                                <Button x:Name="BtnShareTour"
                                        Style="{StaticResource RightSideActionButtonStyle}"
                                        Click="BtnShareTour_Click">
                                    <StackPanel Orientation="Horizontal"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center">
                                        <TextBlock FontFamily="Segoe MDL2 Assets"
           Text="&#xE72D;"
           FontSize="13"
           Margin="0,0,7,0"
                                                   Foreground="#666666"/>
                                        <TextBlock Text="공유하기"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>