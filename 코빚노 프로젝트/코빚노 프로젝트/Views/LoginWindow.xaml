<Window x:Class="코빚노_프로젝트.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Spot Stay Login"
        Width="860"
        Height="560"
        MinWidth="860"
        MinHeight="560"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        WindowStyle="None"
        ResizeMode="CanResize"
        Background="#F7F8FA"
        FontFamily="Malgun Gothic">

    <Window.Resources>

        <!-- 아이디 입력창 -->
        <Style x:Key="LoginInputBox" TargetType="TextBox">
            <Setter Property="Height" Value="42"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Foreground" Value="#333333"/>
            <Setter Property="Background" Value="#FAFAFA"/>
            <Setter Property="BorderBrush" Value="#E8E8E8"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"/>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#FFCC00"/>
                                <Setter Property="Background" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 비밀번호 입력창 -->
        <Style x:Key="LoginPasswordBox" TargetType="PasswordBox">
            <Setter Property="Height" Value="42"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Foreground" Value="#333333"/>
            <Setter Property="Background" Value="#FAFAFA"/>
            <Setter Property="BorderBrush" Value="#E8E8E8"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"/>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#FFCC00"/>
                                <Setter Property="Background" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 노란 로그인 버튼 -->
        <Style x:Key="MainLoginButton" TargetType="Button">
            <Setter Property="Height" Value="44"/>
            <Setter Property="Background" Value="#FFCC00"/>
            <Setter Property="Foreground" Value="#333333"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#F5C400"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#E8B800"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 소셜 버튼 -->
        <Style x:Key="SocialButton" TargetType="Button">
            <Setter Property="Height" Value="40"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#555555"/>
            <Setter Property="BorderBrush" Value="#E8E8E8"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 로그인 상태 유지 체크박스 -->
        <Style x:Key="RememberCheckBox" TargetType="CheckBox">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#777777"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel Orientation="Horizontal">
                            <Border x:Name="Box"
                                    Width="16"
                                    Height="16"
                                    CornerRadius="4"
                                    Background="White"
                                    BorderBrush="#DDDDDD"
                                    BorderThickness="1.5"
                                    VerticalAlignment="Center">
                                <TextBlock x:Name="CheckMark"
                                           Text="✓"
                                           FontSize="11"
                                           FontWeight="Bold"
                                           Foreground="#333333"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Visibility="Collapsed"/>
                            </Border>

                            <ContentPresenter Margin="7,0,0,0"
                                              VerticalAlignment="Center"/>
                        </StackPanel>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Box" Property="Background" Value="#FFCC00"/>
                                <Setter TargetName="Box" Property="BorderBrush" Value="#FFCC00"/>
                                <Setter TargetName="CheckMark" Property="Visibility" Value="Visible"/>
                            </Trigger>

                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Box" Property="BorderBrush" Value="#FFCC00"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 커스텀 상단바 버튼 -->
        <Style x:Key="WindowTopButton" TargetType="Button">
            <Setter Property="Width" Value="42"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#444444"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#EEEEEE"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CloseWindowTopButton"
               TargetType="Button"
               BasedOn="{StaticResource WindowTopButton}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E81123"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

    </Window.Resources>

    <Border Margin="8"
            Background="#F7F8FA"
            BorderBrush="#E0E0E0"
            BorderThickness="1"
            CornerRadius="12"
            ClipToBounds="True">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="34"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- 커스텀 상단바 -->
            <Grid Grid.Row="0"
                  Background="White"
                  MouseLeftButtonDown="CustomTitleBar_MouseLeftButtonDown">

                <TextBlock Text="Spot Stay Login"
                           VerticalAlignment="Center"
                           Margin="14,0,0,0"
                           FontSize="12"
                           FontWeight="Bold"
                           Foreground="#333333"/>

                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right">

                    <Button x:Name="BtnWindowMinimize"
                            Content="─"
                            Style="{StaticResource WindowTopButton}"
                            Click="BtnWindowMinimize_Click"/>

                    <Button x:Name="BtnWindowMaximize"
                            Content="□"
                            Style="{StaticResource WindowTopButton}"
                            Click="BtnWindowMaximize_Click"/>

                    <Button x:Name="BtnWindowClose"
                            Content="✕"
                            Style="{StaticResource CloseWindowTopButton}"
                            Click="BtnWindowClose_Click"/>
                </StackPanel>
            </Grid>

            <!-- 로그인 화면 전체 -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="420"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- 왼쪽 로그인 패널 -->
                <Border Grid.Column="0"
                        Background="White">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="30"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="1"
                                    VerticalAlignment="Center"
                                    Margin="50,0">

                            <TextBlock FontSize="22"
                                       FontWeight="ExtraBold">
                                <Run Text="Spot"/>
                                <Run Text="Stay" Foreground="#FFCC00"/>
                            </TextBlock>

                            <TextBlock Text="전국 관광지 탐색 플랫폼"
                                       FontSize="12"
                                       Foreground="#BBBBBB"
                                       Margin="0,4,0,32"/>

                            <TextBlock Text="아이디"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="#555555"
                                       Margin="0,0,0,6"/>

                            <TextBox x:Name="TxtId"
                                     Style="{StaticResource LoginInputBox}"
                                     Text="{Binding UserId, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0,0,0,16"/>

                            <TextBlock Text="비밀번호"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="#555555"
                                       Margin="0,0,0,6"/>

                            <PasswordBox x:Name="TxtPw"
                                         Style="{StaticResource LoginPasswordBox}"
                                         PasswordChanged="TxtPw_PasswordChanged"
                                         Margin="0,0,0,16"/>

                            <!-- 로그인 유지 / 비밀번호 찾기 -->
                            <Grid Margin="0,0,0,22">
                                <CheckBox x:Name="ChkRememberLogin"
                                          Content="로그인 상태 유지"
                                          IsChecked="True"
                                          Style="{StaticResource RememberCheckBox}"
                                          HorizontalAlignment="Left"
                                          VerticalAlignment="Center"/>

                                <TextBlock Text="비밀번호 찾기"
                                           FontSize="12"
                                           Foreground="#1A73E8"
                                           HorizontalAlignment="Right"
                                           VerticalAlignment="Center"
                                           Cursor="Hand"/>
                            </Grid>

                            <Button Content="로그인"
                                    Style="{StaticResource MainLoginButton}"
                                    Click="BtnDoLogin_Click"
                                    Margin="0,0,0,14"/>

                            <!-- 구분선 -->
                            <Grid Margin="0,0,0,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0"
                                        Height="1"
                                        Background="#F0F0F0"
                                        VerticalAlignment="Center"/>

                                <TextBlock Grid.Column="1"
                                           Text="또는 소셜 계정으로"
                                           FontSize="11"
                                           Foreground="#CCCCCC"
                                           HorizontalAlignment="Center"/>

                                <Border Grid.Column="2"
                                        Height="1"
                                        Background="#F0F0F0"
                                        VerticalAlignment="Center"/>
                            </Grid>

                            <!-- 소셜 로그인 -->
                            <Grid Margin="0,0,0,24">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Button Grid.Column="0"
                                        Content="K 카카오"
                                        Background="#FEE500"
                                        BorderBrush="#FEE500"
                                        Foreground="#333333"
                                        Style="{StaticResource SocialButton}"/>

                                <Button Grid.Column="2"
                                        Content="N 네이버"
                                        Background="#03C75A"
                                        BorderBrush="#03C75A"
                                        Foreground="White"
                                        Style="{StaticResource SocialButton}"/>

                                <Button Grid.Column="4"
                                        Content="G 구글"
                                        Style="{StaticResource SocialButton}"/>
                            </Grid>

                            <TextBlock FontSize="12"
                                       Foreground="#AAAAAA"
                                       HorizontalAlignment="Center">
                                <Run Text="아직 계정이 없으신가요? "/>
                                <Run Text="회원가입"
                                     Foreground="#333333"
                                     FontWeight="Bold"/>
                            </TextBlock>

                        </StackPanel>
                    </Grid>
                </Border>

                <!-- 오른쪽 소개 패널 -->
                <Grid Grid.Column="1"
                      ClipToBounds="True">

                    <Grid.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#FFFBEA" Offset="0"/>
                            <GradientStop Color="#FFF8CC" Offset="0.45"/>
                            <GradientStop Color="#E8F4FF" Offset="1"/>
                        </LinearGradientBrush>
                    </Grid.Background>

                    <!-- 통통 튀는 오른쪽 위 큰 버블 -->
                    <Ellipse Width="420"
                             Height="420"
                             Fill="#FFCC00"
                             Opacity="0.18"
                             HorizontalAlignment="Right"
                             VerticalAlignment="Top"
                             Margin="0,-145,-130,0"
                             RenderTransformOrigin="0.5,0.5"
                             IsHitTestVisible="False">
                        <Ellipse.RenderTransform>
                            <TransformGroup>
                                <ScaleTransform x:Name="BubbleTopRightScale"/>
                                <TranslateTransform x:Name="BubbleTopRightMove"/>
                            </TransformGroup>
                        </Ellipse.RenderTransform>
                    </Ellipse>

                    <!-- 통통 튀는 왼쪽 아래 큰 버블 -->
                    <Ellipse Width="300"
                             Height="300"
                             Fill="#1A73E8"
                             Opacity="0.10"
                             HorizontalAlignment="Left"
                             VerticalAlignment="Bottom"
                             Margin="-105,0,0,-95"
                             RenderTransformOrigin="0.5,0.5"
                             IsHitTestVisible="False">
                        <Ellipse.RenderTransform>
                            <TransformGroup>
                                <ScaleTransform x:Name="BubbleBottomLeftScale"/>
                                <TranslateTransform x:Name="BubbleBottomLeftMove"/>
                            </TransformGroup>
                        </Ellipse.RenderTransform>
                    </Ellipse>

                    <!-- 노란 작은 버블 -->
                    <Ellipse Width="92"
                             Height="92"
                             Fill="#FFCC00"
                             Opacity="0.20"
                             HorizontalAlignment="Right"
                             VerticalAlignment="Center"
                             Margin="0,0,145,150"
                             RenderTransformOrigin="0.5,0.5"
                             IsHitTestVisible="False">
                        <Ellipse.RenderTransform>
                            <TransformGroup>
                                <ScaleTransform x:Name="BubbleSmallOneScale"/>
                                <TranslateTransform x:Name="BubbleSmallOneMove"/>
                            </TransformGroup>
                        </Ellipse.RenderTransform>
                    </Ellipse>

                    <!-- 파란 작은 버블 -->
                    <Ellipse Width="62"
                             Height="62"
                             Fill="#1A73E8"
                             Opacity="0.11"
                             HorizontalAlignment="Left"
                             VerticalAlignment="Center"
                             Margin="160,-160,0,0"
                             RenderTransformOrigin="0.5,0.5"
                             IsHitTestVisible="False">
                        <Ellipse.RenderTransform>
                            <TransformGroup>
                                <ScaleTransform x:Name="BubbleSmallTwoScale"/>
                                <TranslateTransform x:Name="BubbleSmallTwoMove"/>
                            </TransformGroup>
                        </Ellipse.RenderTransform>
                    </Ellipse>

                    <!-- 연한 초록 포인트 버블 -->
                    <Ellipse Width="48"
                             Height="48"
                             Fill="#1A7A4A"
                             Opacity="0.08"
                             HorizontalAlignment="Right"
                             VerticalAlignment="Bottom"
                             Margin="0,0,260,130"
                             RenderTransformOrigin="0.5,0.5"
                             IsHitTestVisible="False">
                        <Ellipse.RenderTransform>
                            <TransformGroup>
                                <ScaleTransform x:Name="BubbleTinyGreenScale"/>
                                <TranslateTransform x:Name="BubbleTinyGreenMove"/>
                            </TransformGroup>
                        </Ellipse.RenderTransform>
                    </Ellipse>

                    <!-- 메인 소개 컨텐츠 -->
                    <StackPanel HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Width="520">

                        <TextBlock Text="KR 대한민국 곳곳을&#x0a;한눈에 탐색하세요"
                                   FontSize="38"
                                   FontWeight="ExtraBold"
                                   Foreground="#333333"
                                   TextAlignment="Center"
                                   LineHeight="48"
                                   Margin="0,0,0,18"/>

                        <TextBlock Text="전국 국립공원, 관광지, 숙소 정보를&#x0a;지도 위에서 쉽고 빠르게 찾아보세요"
                                   FontSize="18"
                                   Foreground="#888888"
                                   TextAlignment="Center"
                                   LineHeight="30"
                                   Margin="0,0,0,44"/>

                        <Border Width="430"
                                Background="White"
                                CornerRadius="22"
                                Padding="26"
                                Margin="0,0,0,18">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="22"
                                                  ShadowDepth="0"
                                                  Opacity="0.08"/>
                            </Border.Effect>

                            <StackPanel>
                                <StackPanel Orientation="Horizontal"
                                            Margin="0,0,0,18">
                                    <Border Width="58"
                                            Height="58"
                                            CornerRadius="16"
                                            Background="#FFFBEA">
                                        <TextBlock Text="🏔️"
                                                   FontSize="30"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>

                                    <StackPanel Margin="16,0,0,0"
                                                VerticalAlignment="Center">
                                        <TextBlock Text="한라산 국립공원"
                                                   FontSize="19"
                                                   FontWeight="Bold"
                                                   Foreground="#222222"/>
                                        <TextBlock Text="제주특별자치도 제주시"
                                                   FontSize="14"
                                                   Foreground="#AAAAAA"
                                                   Margin="0,3,0,0"/>
                                    </StackPanel>
                                </StackPanel>

                                <StackPanel Orientation="Horizontal">
                                    <Border Background="#EAFAF1"
                                            CornerRadius="10"
                                            Padding="10,4"
                                            Margin="0,0,8,0">
                                        <TextBlock Text="국립공원"
                                                   FontSize="13"
                                                   FontWeight="Bold"
                                                   Foreground="#1A7A4A"/>
                                    </Border>

                                    <Border Background="#FFFBEA"
                                            CornerRadius="10"
                                            Padding="10,4"
                                            Margin="0,0,8,0">
                                        <TextBlock Text="★ 4.9"
                                                   FontSize="13"
                                                   FontWeight="Bold"
                                                   Foreground="#A07800"/>
                                    </Border>

                                    <Border Background="#E8F4FF"
                                            CornerRadius="10"
                                            Padding="10,4">
                                        <TextBlock Text="주변 숙소 12개"
                                                   FontSize="13"
                                                   FontWeight="Bold"
                                                   Foreground="#1A73E8"/>
                                    </Border>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Grid Width="430">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="14"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="14"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0"
                                    Background="#F7F8FA"
                                    CornerRadius="16"
                                    Padding="18">
                                <StackPanel>
                                    <TextBlock Text="23"
                                               FontSize="26"
                                               FontWeight="ExtraBold"
                                               Foreground="#FFCC00"
                                               HorizontalAlignment="Center"/>
                                    <TextBlock Text="국립공원"
                                               FontSize="13"
                                               Foreground="#AAAAAA"
                                               HorizontalAlignment="Center"
                                               Margin="0,3,0,0"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="2"
                                    Background="#F7F8FA"
                                    CornerRadius="16"
                                    Padding="18">
                                <StackPanel>
                                    <TextBlock Text="1.2k"
                                               FontSize="26"
                                               FontWeight="ExtraBold"
                                               Foreground="#333333"
                                               HorizontalAlignment="Center"/>
                                    <TextBlock Text="관광지"
                                               FontSize="13"
                                               Foreground="#AAAAAA"
                                               HorizontalAlignment="Center"
                                               Margin="0,3,0,0"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="4"
                                    Background="#F7F8FA"
                                    CornerRadius="16"
                                    Padding="18">
                                <StackPanel>
                                    <TextBlock Text="8.4k"
                                               FontSize="26"
                                               FontWeight="ExtraBold"
                                               Foreground="#333333"
                                               HorizontalAlignment="Center"/>
                                    <TextBlock Text="숙소"
                                               FontSize="13"
                                               Foreground="#AAAAAA"
                                               HorizontalAlignment="Center"
                                               Margin="0,3,0,0"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </StackPanel>

                    <!-- 통통 튀는 버블 애니메이션 -->
                    <Grid.Triggers>
                        <EventTrigger RoutedEvent="Loaded">
                            <BeginStoryboard>
                                <Storyboard>

                                    <!-- 오른쪽 위 큰 버블 -->
                                    <DoubleAnimation Storyboard.TargetName="BubbleTopRightMove"
                                                     Storyboard.TargetProperty="Y"
                                                     From="0"
                                                     To="46"
                                                     Duration="0:0:2.7"
                                                     AutoReverse="True"
                                                     RepeatBehavior="Forever">
                                        <DoubleAnimation.EasingFunction>
                                            <BounceEase Bounces="2"
                                                        Bounciness="2.2"
                                                        EasingMode="EaseOut"/>
                                        </DoubleAnimation.EasingFunction>
                                    </DoubleAnimation>

                                    <DoubleAnimation Storyboard.TargetName="BubbleTopRightMove"
                                                     Storyboard.TargetProperty="X"
                                                     From="0"
                                                     To="-28"
                                                     Duration="0:0:4.2"
                                                     AutoReverse="True"
                                                     RepeatBehavior="Forever"/>

                                    <DoubleAnimation Storyboard.TargetName="BubbleTopRightScale"
                                                     Storyboard.TargetProperty="ScaleX"
                                                     From="1"
                                                     To="1.045"
                                                     Duration="0:0:2.7"
                                                     AutoReverse="True"
                                                     RepeatBehavior="Forever"/>

                                    <DoubleAnimation Storyboard.TargetName="BubbleTopRightScale"
                                                     Storyboard.TargetProperty="ScaleY"
                                                     From="1"
                                                     To="1.045"
                                                     Duration="0:0:2.7"
                                                     AutoReverse="True"
                                                     RepeatBehavior="Forever"/>

                                    <!-- 왼쪽 아래 큰 버블 -->
                                    <DoubleAnimation Storyboard.TargetName="BubbleBottomLeftMove"
                                                     Storyboard.TargetProperty="Y"
                                                     From="0"
                                                     To="-42"
                                                     Duration="0:0:3.1"
                                                     AutoReverse="True"
                                                     RepeatBehavior="Forever">
                                        <DoubleAnimation.EasingFunction>
                                            <BounceEase Bounces="2"
                                                        Bounciness="2.4"
                                                        EasingMode="EaseOut"/>
                                        </DoubleAnimation.EasingFunction>
                                    </DoubleAnimation>

                                    <DoubleAnimation Storyboard.TargetName="BubbleBottomLeftMove"
                                                     Storyboard.TargetProperty="X"
                                                     From="0"
                                                     To="32"
                                                     Duration="0:0:4.6"
                                                     AutoReverse="True"
                                                     RepeatBehavior="Forever"/>

                                    <DoubleAnimation Storyboard.TargetName="BubbleBottomLeftScale"
                                                     Storyboard.TargetProperty="ScaleX"
                                                     From="1"
                                                     To="1.055"
                                                     Duration="0:0:3.1"
