<Window x:Class="코빚노_프로젝트.MyPageWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="마이페이지"
        Width="980"
        Height="744"
        MinWidth="860"
        MinHeight="620"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="CanResize"
        Background="#F7F8FA"
        FontFamily="Malgun Gothic">

    <Window.Resources>

        <Style x:Key="MenuButton" TargetType="Button">
            <Setter Property="Height" Value="42"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="20,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#777777"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="YellowButton" TargetType="Button">
            <Setter Property="Height" Value="34"/>
            <Setter Property="Background" Value="#FFCC00"/>
            <Setter Property="Foreground" Value="#333333"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="17">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="WindowTopButton" TargetType="Button">
            <Setter Property="Width" Value="42"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#444444"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#EEEEEE"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CloseWindowTopButton" TargetType="Button" BasedOn="{StaticResource WindowTopButton}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E81123"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

    </Window.Resources>

    <Border Margin="8"
            Background="#F7F8FA"
            BorderBrush="#E0E0E0"
            BorderThickness="1"
            CornerRadius="12"
            ClipToBounds="True">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="34"/>
                <RowDefinition Height="58"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- 커스텀 윈도우 상단바 -->
            <Grid Grid.Row="0"
                  Background="White"
                  MouseLeftButtonDown="CustomTitleBar_MouseLeftButtonDown">

                <TextBlock Text="Spot Stay MyPage"
                           VerticalAlignment="Center"
                           Margin="14,0,0,0"
                           FontSize="12"
                           FontWeight="Bold"
                           Foreground="#333333"/>

                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right">

                    <Button x:Name="BtnWindowMinimize"
                            Content="─"
                            Style="{StaticResource WindowTopButton}"
                            Click="BtnWindowMinimize_Click"/>

                    <Button x:Name="BtnWindowMaximize"
                            Content="□"
                            Style="{StaticResource WindowTopButton}"
                            Click="BtnWindowMaximize_Click"/>

                    <Button x:Name="BtnWindowClose"
                            Content="✕"
                            Style="{StaticResource CloseWindowTopButton}"
                            Click="BtnWindowClose_Click"/>
                </StackPanel>
            </Grid>

            <!-- 상단 -->
            <Border Grid.Row="1"
                    Background="White"
                    BorderBrush="#ECECEC"
                    BorderThickness="0,1,0,1"
                    Padding="20,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="170"/>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="140"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               VerticalAlignment="Center"
                               FontSize="17"
                               FontWeight="ExtraBold">
                        <Run Text="Spot"/>
                        <Run Text="Stay" Foreground="#FFCC00"/>
                    </TextBlock>

                    <Button Grid.Column="1"
                            Content="← 지도로 돌아가기"
                            Background="Transparent"
                            BorderThickness="0"
                            Foreground="#888888"
                            Cursor="Hand"
                            Click="BtnBack_Click"/>

                    <TextBlock Grid.Column="2"
                               Text="마이페이지"
                               FontSize="16"
                               FontWeight="ExtraBold"
                               Foreground="#222222"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- 본문 -->
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- 왼쪽 프로필 -->
                <Border Grid.Column="0"
                        Background="White"
                        BorderBrush="#ECECEC"
                        BorderThickness="0,0,1,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="210"/>
                            <RowDefinition Height="76"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center">
                            <Border Width="70"
                                    Height="70"
                                    CornerRadius="35"
                                    Background="#FFCC00"
                                    Margin="0,0,0,10">
                                <TextBlock x:Name="TxtAvatar"
                                           Text="👤"
                                           FontSize="28"
                                           FontWeight="ExtraBold"
                                           Foreground="#333333"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>

                            <TextBlock x:Name="TxtUserName"
                                       Text="사용자"
                                       FontSize="16"
                                       FontWeight="Bold"
                                       HorizontalAlignment="Center"/>

                            <TextBlock x:Name="TxtUserId"
                                       Text="@user"
                                       FontSize="11"
                                       Foreground="#AAAAAA"
                                       HorizontalAlignment="Center"
                                       Margin="0,3,0,10"/>

                            <Border Background="#FFFBEA"
                                    BorderBrush="#FFCC00"
                                    BorderThickness="1"
                                    CornerRadius="12"
                                    Padding="10,4">
                                <TextBlock Text="🏆 여행 마스터"
                                           FontSize="11"
                                           FontWeight="Bold"
                                           Foreground="#A07800"/>
                            </Border>
                        </StackPanel>

                        <UniformGrid Grid.Row="1"
             Columns="2"
             Background="White"
             Margin="24,0,24,0"
             VerticalAlignment="Center">

    <StackPanel VerticalAlignment="Center"
                HorizontalAlignment="Center">
        <TextBlock x:Name="TxtSideFavoriteCount"
                   Text="0"
                   FontSize="20"
                   FontWeight="ExtraBold"
                   HorizontalAlignment="Center"/>
        <TextBlock Text="즐겨찾기"
                   FontSize="11"
                   Foreground="#AAAAAA"
                   HorizontalAlignment="Center"
                   Margin="0,3,0,0"/>
    </StackPanel>

    <StackPanel VerticalAlignment="Center"
                HorizontalAlignment="Center">
        <TextBlock x:Name="TxtSideReviewCount"
                   Text="0"
                   FontSize="20"
                   FontWeight="ExtraBold"
                   HorizontalAlignment="Center"/>
        <TextBlock Text="리뷰"
                   FontSize="11"
                   Foreground="#AAAAAA"
                   HorizontalAlignment="Center"
                   Margin="0,3,0,0"/>
    </StackPanel>

</UniformGrid>

                        <StackPanel Grid.Row="2" Margin="0,12,0,0">
                            <TextBlock Text="메뉴"
                                       FontSize="10"
                                       Foreground="#CCCCCC"
                                       Margin="20,0,0,4"/>

                            <Button Content="👤  내 정보 overview"
                                    Style="{StaticResource MenuButton}"
                                    Background="#FFFBEA"
                                    FontWeight="Bold"
                                    Foreground="#333333"/>

                            <Button x:Name="BtnMenuFavorite"
                                    Content="♡  즐겨찾기       0"
                                    Style="{StaticResource MenuButton}"/>

                            <Button x:Name="BtnMenuReview"
                                    Content="★  내 리뷰       0"
                                    Style="{StaticResource MenuButton}"/>

                            <TextBlock Text="설정"
                                       FontSize="10"
                                       Foreground="#CCCCCC"
                                       Margin="20,12,0,4"/>

                            <Button Content="🔔  알림 설정"
                                    Style="{StaticResource MenuButton}"/>

                            <Button Content="🔒  보안 설정"
                                    Style="{StaticResource MenuButton}"/>

                            <Button Content="🚪  로그아웃"
                                    Style="{StaticResource MenuButton}"
                                    Foreground="#FF6B6B"
                                    Click="BtnLogout_Click"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- 오른쪽 내용 -->
                <ScrollViewer Grid.Column="1"
                              VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="20">

                        <!-- 통계 -->
                        <TextBlock Text="📊 내 여행 통계"
           FontSize="16"
           FontWeight="ExtraBold"
           Margin="0,6,0,14"/>

                        <Grid HorizontalAlignment="Stretch"
      Margin="0,0,0,26">

                            <StackPanel Orientation="Horizontal"
                HorizontalAlignment="Center">

                                <!-- 즐겨찾기 카드 -->
                                <Border Background="White"
                Width="317"
                Height="145"
                CornerRadius="16"
                Padding="18"
                Margin="0,0,18,0">
                                    <StackPanel VerticalAlignment="Center">

                                        <TextBlock Text="♥"
                           FontSize="34"
                           Foreground="#FF4B5C"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"/>

                                        <TextBlock x:Name="TxtTopFavoriteCount"
                           Text="0"
                           FontSize="26"
                           FontWeight="ExtraBold"
                           Foreground="#222222"
                           HorizontalAlignment="Center"
                           Margin="0,6,0,0"/>

                                        <TextBlock Text="즐겨찾기"
                           FontSize="12"
                           Foreground="#AAAAAA"
                           HorizontalAlignment="Center"
                           Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Border>

                                <!-- 작성 리뷰 카드 -->
                                <Border Background="White"
                Width="321"
                Height="143"
                CornerRadius="16"
                Padding="18"
                Margin="18,0,0,0">
                                    <StackPanel VerticalAlignment="Center">

                                        <TextBlock Text="★"
                           FontSize="38"
                           Foreground="#FFCC00"
                           FontWeight="ExtraBold"
                           HorizontalAlignment="Center"/>

                                        <TextBlock x:Name="TxtTopReviewCount"
                           Text="0"
                           FontSize="26"
                           FontWeight="ExtraBold"
                           Foreground="#222222"
                           HorizontalAlignment="Center"
                           Margin="0,2,0,0"/>

                                        <TextBlock Text="작성 리뷰"
                           FontSize="12"
                           Foreground="#AAAAAA"
                           HorizontalAlignment="Center"
                           Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Border>

                            </StackPanel>
                        </Grid>
                        <!-- 즐겨찾기 -->
                        <StackPanel Orientation="Horizontal"
            Margin="0,0,0,10"
            HorizontalAlignment="Left">
                            <TextBlock Text="♥"
               FontSize="16"
               Foreground="#FF4B5C"
               FontWeight="ExtraBold"
               VerticalAlignment="Center"
               Margin="0,0,6,0"/>

                            <TextBlock Text="찜목록"
               FontSize="15"
               Foreground="#222222"
               FontWeight="ExtraBold"
               VerticalAlignment="Center"/>
                        </StackPanel>

                        <TextBlock x:Name="TxtFavoriteEmpty"
                                   Text="등록한 즐겨찾기가 없습니다."
                                   FontSize="12"
                                   Foreground="#AAAAAA"
                                   Margin="0,0,0,14"
                                   Visibility="Collapsed"/>

                        <ItemsControl x:Name="MyFavoriteList"
                                      Margin="0,0,0,20">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="White"
                                            CornerRadius="14"
                                            Padding="16"
                                            Margin="0,0,0,10"
                                            BorderBrush="#F0F0F0"
                                            BorderThickness="1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="90"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Grid.Column="0">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="♥"
                                                               FontSize="14"
                                                               Foreground="#FF6B6B"
                                                               FontWeight="Bold"
                                                               Margin="0,0,6,0"/>

                                                    <TextBlock Text="{Binding TargetName, TargetNullValue=장소명 없음}"
           FontWeight="Bold"
           FontSize="14"
           Foreground="#222222"
           TextTrimming="CharacterEllipsis"/>
                                                </StackPanel>

                                                <TextBlock Text="관광지"
           FontSize="11"
           Foreground="#AAAAAA"
           Margin="20,4,0,0"/>
                                            </StackPanel>

                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding CreatedAt, StringFormat={}{0:yyyy.MM.dd}}"
                                                       FontSize="11"
                                                       Foreground="#BBBBBB"
                                                       HorizontalAlignment="Right"
                                                       VerticalAlignment="Center"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- 리뷰 -->
                        <StackPanel Orientation="Horizontal"
                                    Margin="0,0,0,10">
                            <TextBlock Text="★"
                                       FontSize="17"
                                       FontWeight="ExtraBold"
                                       Foreground="#FFCC00"
                                       VerticalAlignment="Center"
                                       Margin="0,0,5,0"/>

                            <TextBlock Text="최근 작성 리뷰"
                                       FontSize="15"
                                       FontWeight="ExtraBold"
                                       Foreground="#222222"
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                        <TextBlock x:Name="TxtReviewEmpty"
                                   Text="작성한 리뷰가 없습니다."
                                   FontSize="12"
                                   Foreground="#AAAAAA"
                                   Margin="0,0,0,14"
                                   Visibility="Collapsed"/>

                        <ItemsControl x:Name="MyReviewList"
                                      Margin="0,0,0,20">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="White"
                                            CornerRadius="14"
                                            Padding="18"
                                            Margin="0,0,0,12"
                                            BorderBrush="#F0F0F0"
                                            BorderThickness="1">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <Grid Grid.Row="0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <StackPanel Orientation="Horizontal"
                                                            VerticalAlignment="Center">
                                                    <TextBlock Text="📍"
                                                               FontSize="13"
                                                               Margin="0,0,5,0"/>

                                                    <TextBlock Text="{Binding TargetName, TargetNullValue=장소명 없음}"
                                                               FontWeight="Bold"
                                                               FontSize="14"
                                                               Foreground="#222222"
                                                               TextTrimming="CharacterEllipsis"/>
                                                </StackPanel>

                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding CreatedAt, StringFormat={}{0:yyyy.MM.dd}}"
                                                           Foreground="#BBBBBB"
                                                           FontSize="11"
                                                           VerticalAlignment="Center"/>
                                            </Grid>

                                            <StackPanel Grid.Row="1"
                                                        Orientation="Horizontal"
                                                        Margin="0,8,0,0">
                                                <Border Background="#FFFBEA"
                                                        CornerRadius="10"
                                                        Padding="8,2">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="★"
                                                                   Foreground="#FFCC00"
                                                                   FontSize="12"
                                                                   FontWeight="Bold"/>

                                                        <TextBlock Text="{Binding Rating}"
                                                                   Foreground="#A07800"
                                                                   FontSize="12"
                                                                   FontWeight="Bold"
                                                                   Margin="4,0,0,0"/>
                                                    </StackPanel>
                                                </Border>

                                                <Border Background="#EAFAF1"
                                                        CornerRadius="10"
                                                        Padding="8,2"
                                                        Margin="6,0,0,0">
                                                    <TextBlock Text="관광지"
           Foreground="#1A7A4A"
           FontSize="11"
           FontWeight="Bold"/>
                                                </Border>
                                            </StackPanel>

                                            <TextBlock Grid.Row="2"
                                                       Text="{Binding Content}"
                                                       TextWrapping="Wrap"
                                                       Foreground="#555555"
                                                       FontSize="13"
                                                       LineHeight="21"
                                                       Margin="0,10,0,0"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Border>
</Window>