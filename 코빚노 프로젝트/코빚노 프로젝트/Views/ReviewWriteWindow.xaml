<Window x:Class="코빚노_프로젝트.ReviewWriteWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="340"
        Height="390"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="Transparent"
        WindowStyle="None"
        AllowsTransparency="True"
        FontFamily="Malgun Gothic">

    <Window.Resources>
        <SolidColorBrush x:Key="AccentBrush" Color="#FFCC00"/>
        <SolidColorBrush x:Key="AccentHoverBrush" Color="#F5C400"/>
        <SolidColorBrush x:Key="AccentTextBrush" Color="#A87A00"/>
    </Window.Resources>

    <Border Background="White"
            CornerRadius="14"
            BorderBrush="#DDDDDD"
            BorderThickness="1">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="48"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="64"/>
            </Grid.RowDefinitions>

            <!-- 헤더 -->
            <Border Grid.Row="0"
                    Background="{StaticResource AccentBrush}"
                    CornerRadius="14,14,0,0">
                <Grid Margin="12,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Border Width="28"
                            Height="28"
                            Background="White"
                            CornerRadius="8"
                            VerticalAlignment="Center">
                        <TextBlock Text="🏠"
                                   FontSize="14"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>

                    <StackPanel Grid.Column="1"
                                Margin="10,6,0,6"
                                VerticalAlignment="Center">
                        <TextBlock x:Name="TxtPlaceName"
                                   Text="장소명"
                                   FontSize="13"
                                   FontWeight="Bold"
                                   Foreground="Black"
                                   TextTrimming="CharacterEllipsis"/>

                        <TextBlock x:Name="TxtPlaceSub"
                                   Text="리뷰를 작성해 주세요"
                                   FontSize="11"
                                   Foreground="#6B5A00"/>
                    </StackPanel>

                    <Button Grid.Column="2"
                            Content="✕"
                            Width="28"
                            Height="28"
                            Background="Transparent"
                            BorderThickness="0"
                            FontWeight="Bold"
                            Cursor="Hand"
                            Click="BtnClose_Click"/>
                </Grid>
            </Border>

            <!-- 본문 -->
            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="14">

                    <!-- 별점 -->
                    <StackPanel Margin="0,0,0,18">
                        <StackPanel Orientation="Horizontal"
                                    Margin="0,0,0,8">
                            <Border Width="3"
                                    Height="14"
                                    Background="{StaticResource AccentBrush}"
                                    CornerRadius="2"
                                    Margin="0,2,6,0"/>
                            <TextBlock Text="별점"
                                       FontWeight="SemiBold"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal"
                                    VerticalAlignment="Center">
                            <Button x:Name="BtnStar1"
                                    Content="★"
                                    Tag="1"
                                    FontSize="28"
                                    Foreground="#D9D9D9"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Padding="0"
                                    Margin="0,0,6,0"
                                    Cursor="Hand"
                                    Click="BtnStar_Click"/>

                            <Button x:Name="BtnStar2"
                                    Content="★"
                                    Tag="2"
                                    FontSize="28"
                                    Foreground="#D9D9D9"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Padding="0"
                                    Margin="0,0,6,0"
                                    Cursor="Hand"
                                    Click="BtnStar_Click"/>

                            <Button x:Name="BtnStar3"
                                    Content="★"
                                    Tag="3"
                                    FontSize="28"
                                    Foreground="#D9D9D9"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Padding="0"
                                    Margin="0,0,6,0"
                                    Cursor="Hand"
                                    Click="BtnStar_Click"/>

                            <Button x:Name="BtnStar4"
                                    Content="★"
                                    Tag="4"
                                    FontSize="28"
                                    Foreground="#D9D9D9"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Padding="0"
                                    Margin="0,0,6,0"
                                    Cursor="Hand"
                                    Click="BtnStar_Click"/>

                            <Button x:Name="BtnStar5"
                                    Content="★"
                                    Tag="5"
                                    FontSize="28"
                                    Foreground="#D9D9D9"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Padding="0"
                                    Margin="0,0,14,0"
                                    Cursor="Hand"
                                    Click="BtnStar_Click"/>

                            <TextBlock x:Name="TxtRatingText"
                                       Text="선택 안 함"
                                       Foreground="{StaticResource AccentTextBrush}"
                                       VerticalAlignment="Center"
                                       FontWeight="SemiBold"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- 리뷰 내용 -->
                    <StackPanel Margin="0,0,0,12">
                        <StackPanel Orientation="Horizontal"
                                    Margin="0,0,0,8">
                            <Border Width="3"
                                    Height="14"
                                    Background="{StaticResource AccentBrush}"
                                    CornerRadius="2"
                                    Margin="0,2,6,0"/>
                            <TextBlock Text="리뷰 내용"
                                       FontWeight="SemiBold"/>
                        </StackPanel>

                        <TextBox x:Name="TxtReviewContent"
                                 Height="110"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 VerticalContentAlignment="Top"
                                 Padding="10"
                                 BorderBrush="#D6D6D6"
                                 TextChanged="TxtReviewContent_TextChanged"
                                 Text=""/>

                        <TextBlock x:Name="TxtCharCount"
                                   Text="0 / 500자"
                                   HorizontalAlignment="Right"
                                   Margin="0,6,0,0"
                                   Foreground="{StaticResource AccentTextBrush}"/>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>

            <!-- 하단 버튼 -->
            <Grid Grid.Row="2"
                  Margin="14,0,14,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="2*"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Content="취소"
                        Height="42"
                        Background="White"
                        BorderBrush="#CFCFCF"
                        Click="BtnCancel_Click"/>

                <Button Grid.Column="2"
                        Content="✈ 리뷰 게시"
                        Height="42"
                        Foreground="Black"
                        FontWeight="Bold"
                        Cursor="Hand"
                        Click="BtnSubmit_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
                            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                            <Setter Property="BorderThickness" Value="1"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="8">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="{StaticResource AccentHoverBrush}"/>
                                    <Setter Property="BorderBrush" Value="{StaticResource AccentHoverBrush}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>
        </Grid>
    </Border>
</Window>